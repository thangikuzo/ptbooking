rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && currentUser().role == 'Admin';
    }

    function isPT() {
      return signedIn() && currentUser().role == 'PT';
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if owns(userId) || isAdmin();
      allow update: if owns(userId) || isAdmin();
      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read, write: if owns(userId) || isAdmin();
      }
    }

    match /wallets/{userId} {
      allow read: if owns(userId) || isAdmin();

      // Demo wallet: client can update its own wallet during deposit/booking flows.
      // Move balance mutations to Cloud Functions before using real money.
      allow create, update: if owns(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /wallet_transactions/{transactionId} {
      allow read: if isAdmin() || (signedIn() && resource.data.user_id == request.auth.uid);
      allow create: if signedIn() && (
        isAdmin() ||
        request.resource.data.user_id == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin() || isPT() || (signedIn() && resource.data.user_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /booking_slots/{slotId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if signedIn();
      allow create, update: if owns(scheduleId) || isAdmin();
      allow delete: if owns(scheduleId) || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin() || (signedIn() && resource.data.user_id == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}
